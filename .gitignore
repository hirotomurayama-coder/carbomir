# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI ドラフトは個人作業履歴なので除外 (data/content/ は管理対象)
/data/ai-drafts/*.json
!/data/ai-drafts/.gitkeep

# Claude Code / preview ローカル設定 (マシン固有パス入り)
/.claude/

# Cron / scheduled tasks log
/tasks.json
